---
// COMPONENTS

import Layout from '../layouts/Layout.astro';
import {Content as IdeasList} from '../data/ideas.mdx';

// METADATA VARIABLES

let title = 'Ideas';
let description = 'Some ideas I had lying around in my head.';
---

<Layout title={title} description={description} robotsTag='noindex, nofollow'>
        <hgroup class="title-meta">
        	<h1>{title}</h1>
        	<p>{description}</p>
        </hgroup>
        <IdeasList />
    </Layout>