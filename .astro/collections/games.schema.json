{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "developer": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "genre": {
      "type": "string"
    },
    "imageURL": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "console": {
      "type": "string"
    },
    "dateBeaten": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    },
    "$schema": {
      "type": "string"
    }
  }
}